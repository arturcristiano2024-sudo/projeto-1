        if hum then hum.Health = 0 end
    end
end)

--------------------------------------------------------------------------------
-- ABA 2: SISTEMAS DE MOVIMENTAÇÃO (FLY & INFINITE JUMP)
--------------------------------------------------------------------------------
local voando = false
local velocidadeVoo = 50
local conexaoVoo = nil

CriarBotao(abaMovimento, "Alternar Voo (Fly)", function()
    voando = not voando
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart
    
    if voando then
        local bV = Instance.new("BodyVelocity")
        bV.Name = "VoltagemVoo"
        bV.Velocity = Vector3.new(0, 0, 0)
        bV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bV.Parent = hrp
        
        local camera = workspace.CurrentCamera
        
        conexaoVoo = RunService.RenderStepped:Connect(function()
            local direcao = Vector3.new(0, 0, 0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then direcao = direcao + camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then direcao = direcao - camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then direcao = direcao - camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then direcao = direcao + camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then direcao = direcao + Vector3.new(0, 1, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then direcao = direcao - Vector3.new(0, 1, 0) end
            
            bV.Velocity = direcao * velocidadeVoo
        end)
    else
        if conexaoVoo then conexaoVoo:Disconnect() end
        local bV = hrp:FindFirstChild("VoltagemVoo")
        if bV then bV:Destroy() end
    end
end)

local puloInfinitoAtivo = false
local conexaoPulo = nil

CriarBotao(abaMovimento, "Alternar Pulo Infinito", function()
    puloInfinitoAtivo = not puloInfinitoAtivo
    if puloInfinitoAtivo then
        conexaoPulo = UserInputService.JumpRequest:Connect(function()
            if LocalPlayer.Character then
                local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                if hum then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    else
        if conexaoPulo then conexaoPulo:Disconnect() end
    end
end)

