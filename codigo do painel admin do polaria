local Abas = {}

local function CriarAba(nomeAba)
    local BotaoAba = Instance.new("TextButton")
    BotaoAba.Name = nomeAba .. "Tab"
    BotaoAba.Parent = Sidebar
    BotaoAba.Size = UDim2.new(1, 0, 0, 35)
    BotaoAba.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    BotaoAba.BorderSizePixel = 0
    BotaoAba.Text = nomeAba
    BotaoAba.TextColor3 = Color3.fromRGB(200, 200, 200)
    BotaoAba.Font = Enum.Font.SourceSans
    BotaoAba.TextSize = 14

    local FrameConteudo = Instance.new("ScrollingFrame")
    FrameConteudo.Name = nomeAba .. "Page"
    FrameConteudo.Parent = Container
    FrameConteudo.Size = UDim2.new(1, 0, 1, 0)
    FrameConteudo.BackgroundTransparency = 1
    FrameConteudo.BorderSizePixel = 0
    FrameConteudo.Visible = false
    FrameConteudo.CanvasSize = UDim2.new(0, 0, 2, 0)
    FrameConteudo.ScrollBarThickness = 6
    
    local LayoutConteudo = Instance.new("UIListLayout")
    LayoutConteudo.Parent = FrameConteudo
    LayoutConteudo.Padding = UDim.new(0, 6)
    
    local Padding = Instance.new("UIPadding", FrameConteudo)
    Padding.PaddingTop = UDim.new(0, 10)
    Padding.PaddingLeft = UDim.new(0, 10)
    Padding.PaddingRight = UDim.new(0, 10)

    BotaoAba.MouseButton1Click:Connect(function()
        for _, aba in pairs(Abas) do
            aba.Frame.Visible = false
            aba.Botao.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            aba.Botao.TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        FrameConteudo.Visible = true
        BotaoAba.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        BotaoAba.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)

    table.insert(Abas, {Botao = BotaoAba, Frame = FrameConteudo})
    return FrameConteudo
end

-- Funções auxiliares para criar elementos visuais dentro das abas
local function CriarBotao(parent, texto, callback)
    local Botao = Instance.new("TextButton")
    Botao.Parent = parent
    Botao.Size = UDim2.new(1, 0, 0, 32)
    Botao.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Botao.BorderSizePixel = 0
    Botao.Text = texto
    Botao.TextColor3 = Color3.fromRGB(255, 255, 255)
    Botao.Font = Enum.Font.SourceSans
    Botao.TextSize = 14
    Botao.MouseButton1Click:Connect(callback)
    return Botao
end

local function CriarInputTexto(parent, placeholder)
    local TextBox = Instance.new("TextBox")
    TextBox.Parent = parent
    TextBox.Size = UDim2.new(1, 0, 0, 32)
    TextBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    TextBox.BorderSizePixel = 0
    TextBox.PlaceholderText = placeholder
    TextBox.Text = ""
    TextBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    TextBox.Font = Enum.Font.SourceSans
    TextBox.TextSize = 14
    return TextBox
end

